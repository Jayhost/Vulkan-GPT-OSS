#version 450
layout(local_size_x = 256) in;
layout(set = 0, binding = 0) buffer X { float x[]; };
layout(set = 0, binding = 1) readonly buffer Y { float y[]; };
layout(push_constant) uniform PC { int n; float weight; } pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < uint(pc.n)) {
        x[i] += y[i] * pc.weight;
    }
}