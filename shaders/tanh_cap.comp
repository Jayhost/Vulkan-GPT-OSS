#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Logits { float logits[]; };

layout(push_constant) uniform PC {
    int   n;
    float cap;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < uint(pc.n)) {
        logits[i] = tanh(logits[i] / pc.cap) * pc.cap;
    }
}