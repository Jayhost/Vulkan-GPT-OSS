#version 450
layout(local_size_x = 32) in;
layout(set = 0, binding = 0) readonly buffer A { uint a[]; };
layout(set = 0, binding = 1) readonly buffer B { float b[]; };
layout(set = 0, binding = 2) writeonly buffer C { float c[]; };
layout(set = 0, binding = 3) readonly buffer Bias { float bias[]; };
layout(push_constant) uniform PC { int M; int K; int has_bias; int expert_idx; int M_per_expert; } pc;

shared float s_sums[32];

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint m = gl_WorkGroupID.x;
    if (m >= uint(pc.M)) return;
    
    float sum = 0.0;
    int expert_off = pc.expert_idx * pc.M_per_expert * pc.K;
    int row_offset = expert_off + int(m) * pc.K;
    
    for (int k = int(tid); k < pc.K; k += 32) {
        int byte_off = (row_offset + k) * 2;
        uint word = a[byte_off / 4];
        uint h = (word >> ((byte_off % 4) * 8)) & 0xFFFF;
        float v = unpackHalf2x16(h).x;
        sum += v * b[k];
    }
    
    s_sums[tid] = sum;
    barrier();
    for (uint s = 16; s > 0; s >>= 1) {
        if (tid < s) s_sums[tid] += s_sums[tid + s];
        barrier();
    }
    
    if (tid == 0) {
        float final_sum = s_sums[0];
        if (pc.has_bias == 1) final_sum += bias[pc.expert_idx * pc.M_per_expert + int(m)];
        c[m] = final_sum;
    }
}