#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer DstBuf { float dst[]; };
layout(set = 0, binding = 1) buffer SrcBuf { float src[]; };
layout(set = 0, binding = 2) buffer WtsBuf { float wts[]; };

layout(push_constant) uniform PC {
    int n;
    int expert_idx;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < pc.n) {
        dst[i] += src[i] * wts[pc.expert_idx];
    }
}