#version 450
layout(local_size_x = 256) in;
layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(set = 0, binding = 1) readonly buffer In { float in_data[]; };
layout(push_constant) uniform PC { int n; int n_experts; } pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < uint(pc.n)) {
        float sum = 0.0;
        for (int e = 0; e < pc.n_experts; e++) {
            sum += in_data[e * pc.n + i];
        }
        out_data[i] = sum;
    }
}